# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=frontier
POSTGRES_USER=frontier
POSTGRES_PASSWORD=your_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Docker Compose (сервер) ───────────────────────────────────────────────────
# Профили для `docker compose build` без ручного --profile (см. docs/ops-server-troubleshooting.md)
# COMPOSE_PROFILES=core,ingest,worker,crawl,paddleocr,mcp,admin

# ── GigaChat / gpt2giga-proxy ─────────────────────────────────────────────────
GIGACHAT_CREDENTIALS=your_gigachat_credentials_here
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Базовый URL API (как в telegram-assistant / gpt2giga)
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
# False — отключить проверку TLS (типично за корпоративным прокси/MITM). True — прод с доверенным CA в образе
GIGACHAT_VERIFY_SSL_CERTS=False
GPT2GIGA_LOG_LEVEL=INFO
# Модели чата (линейка GigaChat 2 Lite / Pro / Max): https://developers.sber.ru/docs/ru/gigachat/models/updates
# Релевантность по умолчанию вызывает Pro (GIGACHAT_MODEL_PRO), если GIGACHAT_MODEL_RELEVANCE не задан.
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_MODEL_LITE=GigaChat-2
GIGACHAT_MODEL_PRO=GigaChat-2-Pro
GIGACHAT_MODEL_MAX=GigaChat-2-Max
# Balanced routing defaults
# GIGACHAT_MODEL_RELEVANCE=GigaChat-2
# GIGACHAT_MODEL_CONCEPTS=GigaChat-2
# GIGACHAT_MODEL_VALENCE=GigaChat-2
# GIGACHAT_MODEL_MCP_SYNTHESIS=GigaChat-2
# GIGACHAT_VISION_MODEL=GigaChat-2-Pro
# GIGACHAT_SESSION_CACHE_ENABLED=true
# GIGACHAT_ESCALATION_ENABLED=true
# GIGACHAT_TOKEN_BUDGET_RELEVANCE=1500
# GIGACHAT_TOKEN_BUDGET_CONCEPTS=1500
# GIGACHAT_TOKEN_BUDGET_RELEVANCE_CONCEPTS=1800
# GIGACHAT_TOKEN_BUDGET_VALENCE=1200
# GIGACHAT_TOKEN_BUDGET_EMBED=1200
# Embeddings:
# - Embeddings = 1024d, 512 tokens
# - EmbeddingsGigaR = 2560d, 4096 tokens
# - GigaEmbeddings-3B-2025-09 = 2048d, 4096 tokens
# Production default today:
# GIGACHAT_EMBEDDINGS_MODEL=EmbeddingsGigaR
# EMBED_DIM=2560
# If you switch embedding model, update EMBED_DIM before rebuild/reindex.
# GIGACHAT_TOKEN_BUDGET_VISION_PROMPT=600
# GIGACHAT_RELEVANCE_GRAY_ZONE=0.1
# GIGACHAT_RC_JOINT_ENABLED=false
# GIGACHAT_RC_JOINT_WORKSPACES=
# GIGACHAT_RC_JOINT_SOURCES=
# GIGACHAT_BALANCE_ALERT_THRESHOLD=100000
# GIGACHAT_MAX_SIMULTANEOUS_REQUESTS=1
# GIGACHAT_MIN_REQUEST_INTERVAL_MS=250
# Опционально: GigaChat-2-Max только для ручечных quality-экспериментов, не как production default
# GIGACHAT_MODEL_RELEVANCE=GigaChat-2-Max
# Vision (картинки): production-safe default = GigaChat-2-Pro; Max нужен только как fallback/escalation
# GIGACHAT_VISION_MODEL=GigaChat-2-Pro

# PaddleOCR (опционально): docker compose --profile core --profile paddleocr up -d paddleocr
# В worker: PADDLEOCR_URL=http://paddleocr:8008
# PADDLEOCR_URL=
# PADDLEOCR_PORT=8008
# true — прогрузка при старте + /readyz/healthcheck healthy после загрузки (рекомендуется в проде)
# false — lazy при первом OCR; до первого запроса /readyz=503, healthcheck ждёт start_period
# LOCAL_OCR_PRELOAD=true
# Сборка paddleocr на сервере: зеркало PyPI (успешно при таймаутах pypi.org)
# PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
# Офлайн-веса (volume paddleocr_models → /root/.paddleocr в контейнере): скопируй каталоги после успешной загрузки
# на машине с доступом к BCE, либо укажи абсолютные пути внутри контейнера:
# LOCAL_OCR_DET_MODEL_DIR=/root/.paddleocr/whl/det/ch/ch_PP-OCRv4_det_infer
# LOCAL_OCR_REC_MODEL_DIR=/root/.paddleocr/whl/rec/cyrillic/cyrillic_PP-OCRv4_rec_infer
# LOCAL_OCR_CLS_MODEL_DIR=/root/.paddleocr/whl/cls/ch_ppocr_mobile_v2.0_cls_infer

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=your_neo4j_password_here

# ── S3 / Cloud.ru ─────────────────────────────────────────────────────────────
S3_ENDPOINT_URL=https://s3.cloud.ru
S3_BUCKET_NAME=your_bucket_name_here
S3_ACCESS_KEY_ID=your_s3_access_key_id_here
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key_here
S3_REGION=ru-central-1
# При переносе со старого .env проверь, что каждая переменная на отдельной строке (без склейки с DB_URL и т.п.)

# ── Worker tuning (shared/config.py — все поля с дефолтами) ──────────────────
# Группа консьюмеров Redis Stream, батч, ретраи, backoff:
# INDEXING_CONSUMER_GROUP=enrichment_workers
# INDEXING_BATCH_SIZE=32
# INDEXING_MAX_RETRIES=5
# INDEXING_BACKOFF_MS=2000
# Порог релевантности для фильтра постов (0.0–1.0):
# DEFAULT_RELEVANCE_THRESHOLD=0.6
# Idle-claim: забрать сообщение у упавшего консьюмера через N мс (дефолт 10 мин):
# INDEXING_CLAIM_IDLE_MS=600000
# Global kill switch for image/video analysis to save tokens.
# When false, worker will not start VisionTask and media posts will be marked as skipped.
# VISION_ENABLED=true
# VISION_CLAIM_IDLE_MS=600000
# VISION_MAX_DELIVERY_COUNT=5
# VISION_DLQ_STREAM=stream:posts:vision:dlq
# REDIS_STREAM_LAG_ALERT_THRESHOLD=1000
# REDIS_STREAM_PENDING_ALERT_THRESHOLD=100
# REDIS_STREAM_OLDEST_PENDING_AGE_ALERT_SECONDS=900
# Очистка мёртвых консьюмеров каждые N секунд (дефолт 30 мин):
# INDEXING_CONSUMER_CLEANUP_INTERVAL=1800

# ── Admin alerting ──────────────────────────────────────────────────────────
# Optional: direct low-balance alerts to Telegram bot.
# TELEGRAM_BOT_TOKEN=
# ALERT_TELEGRAM_CHAT_ID=@your_alert_channel
# TELEGRAM_ALERT_PROXY_URL=socks5://xray:10808
# ADMIN_GIGACHAT_BALANCE_REFRESH_CRON=*/1 * * * *
# PROMETHEUS_URL=http://prometheus:9090

# ── GigaChat Vision ───────────────────────────────────────────────────────────
# Текущий worker читает GIGACHAT_VISION_MODEL и GIGACHAT_TOKEN_BUDGET_VISION_PROMPT.
# PADDLEOCR_URL включает дополнительный OCR поверх GigaChat Vision.
# GIGACHAT_VISION_MODEL=GigaChat-2-Pro
# GIGACHAT_TOKEN_BUDGET_VISION_PROMPT=600

# ── S3 расширенные настройки ──────────────────────────────────────────────────
# S3_ADDRESSING_STYLE=path          # path (Cloud.ru) | virtual (AWS)
# AWS_SIGNATURE_VERSION=s3v4
# S3_CONNECT_TIMEOUT_SEC=30
# S3_READ_TIMEOUT_SEC=60
# S3_MAX_RETRY_ATTEMPTS=3

# ── OpenRouter (не используется текущим compose) ──────────────────────────────
# В старом проекте ключ шёл в кастомный fallback внутри gpt2giga-proxy.
# Здесь прокси — только gpt2giga (run_proxy.py); worker ходит в OPENAI_API_BASE → gpt2giga-proxy.
# Чтобы реально использовать OpenRouter, нужна отдельная доработка прокси или второй LLM-endpoint.
# OPENROUTER_API_KEY=
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Telegram accounts ─────────────────────────────────────────────────────────
TG_API_ID_0=your_telegram_api_id_here
TG_API_HASH_0=your_telegram_api_hash_here
TG_API_ID_1=
TG_API_HASH_1=

# Telethon → DC Telegram: только SOCKS5 или MTProxy. gpt2giga-proxy (GigaChat) — отдельный сервис, сюда НЕ писать.
# Удобно одной строкой (host:port:user:password):
# TG_SOCKS5=HOST:PORT:USER:PASS
# Алиас той же строки: TG_PROXY_DSN=...
# Или по полям:
# TG_PROXY_HOST=
# TG_PROXY_PORT=1080
# TG_PROXY_USER=
# TG_PROXY_PASS=
# Как в docs/README.md (WireGuard): WG_SOCKS_HOST / WG_SOCKS_PORT (+ USER/PASS при необходимости)
# MTProxy (приоритет над SOCKS5, если заданы host+secret):
# MTPROXY_HOST=
# MTPROXY_PORT=443
# MTPROXY_SECRET=
# Xray/VLESS Reality -> локальный SOCKS5 sidecar для ingest.
# Best practice: не уводить весь контейнер в TUN, а дать Telethon локальный socks proxy.
# При включении xray задай TG_PROXY_HOST=xray и TG_PROXY_PORT=10808, а MTPROXY_* / TG_SOCKS5 очисти.
# XRAY_VLESS_ADDRESS=your_vless_server_here
# XRAY_VLESS_PORT=443
# XRAY_VLESS_ID=your_vless_uuid_here
# XRAY_VLESS_FLOW=xtls-rprx-vision
# XRAY_REALITY_SNI=your_reality_sni_here
# XRAY_REALITY_FP=chrome
# XRAY_REALITY_PBK=your_reality_public_key_here
# XRAY_REALITY_SID=your_reality_short_id_here
# XRAY_SOCKS_PORT=10808
# XRAY_LOG_LEVEL=warning
# Жёстко требовать прокси в environment (не учитывает только proxy_config в БД): 1 / true / on
# TG_REQUIRE_PROXY=1

# ── Worker (enrichment) ───────────────────────────────────────────────────────
# Параллельных обработчиков постов в одном батче (релевантность/embed → GigaChat). По умолчанию 4.
# INDEXING_MAX_CONCURRENCY=1
# Если у тарифа/flow только один одновременный запрос к GigaChat, лучше держать и worker, и сам клиент в single-flight режиме:
# GIGACHAT_MAX_SIMULTANEOUS_REQUESTS=1
# GIGACHAT_MIN_REQUEST_INTERVAL_MS=250

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=your_grafana_password_here
LOG_LEVEL=INFO

# ── SearXNG ───────────────────────────────────────────────────────────────────
# searxng/settings.yml is server-local because it contains server.secret_key.
# Template: searxng/settings.example.yml
# Generate/rotate on the server:
#   bash scripts/server-ensure-searxng-secret.sh
SEARXNG_URL=http://searxng:8080
SEARXNG_ENABLED=true
SEARXNG_TIMEOUT_SECONDS=8

# ── Security ───────────────────────────────────────────────────────────────────
# Admin (8101) and MCP (8100) are bound to 0.0.0.0 for LAN access.
# Do not expose them directly to the internet without firewall/VPN/reverse-proxy auth.
# CORS: set to specific origin(s) if needed, e.g. ["http://192.168.31.100"]
ALLOWED_ORIGINS=["*"]
