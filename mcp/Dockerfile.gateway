FROM python:3.11-slim

WORKDIR /app

ARG PIP_INDEX_URL=

RUN if [ -n "$PIP_INDEX_URL" ]; then \
      pip install --no-cache-dir -i "$PIP_INDEX_URL" \
        httpx>=0.27.0 \
        "mcp[cli]>=1.0.0"; \
    else \
      pip install --no-cache-dir \
        httpx>=0.27.0 \
        "mcp[cli]>=1.0.0"; \
    fi

COPY mcp/mcp_gateway.py /app/mcp/mcp_gateway.py

ENV PYTHONPATH=/app

EXPOSE 8102

CMD ["python", "mcp/mcp_gateway.py"]
